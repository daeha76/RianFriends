{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Llm": {
    "Provider": "Anthropic",
    "ConversationModel": "claude-sonnet-4-5",
    "BatchModel": "claude-haiku-4-5"
  }
}
